# Routing & App Router Conventions

## Route Structure

All public pages live inside the `(marketing)` route group:

```
app/
├── layout.jsx                          # Root — <html>, fonts, providers
├── page.jsx                            # / (Home)
├── not-found.jsx                       # Global 404
├── error.jsx                           # Global error ("use client")
├── loading.jsx                         # Global skeleton
├── sitemap.js
├── robots.js
│
├── (marketing)/                        # Route group — no URL impact
│   ├── layout.jsx                      # Navbar + Footer wrapper
│   ├── about/page.jsx
│   ├── products/
│   │   ├── page.jsx
│   │   └── [slug]/
│   │       ├── page.jsx
│   │       └── not-found.jsx
│   ├── services/
│   │   ├── page.jsx
│   │   ├── consultants/page.jsx
│   │   ├── maintenance/page.jsx
│   │   └── inspections/page.jsx
│   ├── industries/distribution-grid/page.jsx
│   ├── solutions/software-application/page.jsx
│   └── contact/page.jsx
│
└── api/
    └── contact/route.js
```

---

## Page File Template

Every `page.jsx` must export `generateMetadata` and a default async component:

```jsx
// app/(marketing)/products/page.jsx

import { getProducts } from '@/lib/api/products'
import ProductsHero from '@/features/products/ProductsHero'
import ProductGrid from '@/features/products/ProductGrid'

export const metadata = {
  title: 'Products | Smart Infrastructure',
  description: 'Browse our full range of smart infrastructure products.',
}

export default async function ProductsPage() {
  const products = await getProducts()

  return (
    <main>
      <ProductsHero />
      <ProductGrid products={products} />
    </main>
  )
}
```

---

## Dynamic Pages — `generateStaticParams` + `generateMetadata`

Always use `generateStaticParams` on dynamic `[slug]` pages to pre-render at build time:

```jsx
// app/(marketing)/products/[slug]/page.jsx

import { getProducts, getProductBySlug } from '@/lib/api/products'
import { notFound } from 'next/navigation'

export async function generateStaticParams() {
  const products = await getProducts()
  return products.map((p) => ({ slug: p.slug }))
}

export async function generateMetadata({ params }) {
  const product = await getProductBySlug(params.slug)
  if (!product) return {}
  return {
    title: `${product.name} | Smart Infrastructure`,
    description: product.summary,
  }
}

export default async function ProductDetailPage({ params }) {
  const product = await getProductBySlug(params.slug)
  if (!product) notFound()

  return (
    <main>
      {/* import from @/features/product-detail/ */}
    </main>
  )
}
```

