# Component Authoring Patterns

## Standard Component Template

```jsx
// src/components/ui/ProductCard/ProductCard.jsx

import Image from "next/image";
import Link from "next/link";
import { cn } from "@/lib/utils/cn";
import { ROUTES } from "@/config/routes";

export default function ProductCard({
  name,
  slug,
  image,
  category,
  summary,
  className,
}) {
  return (
    <article
      className={cn(
        "bg-[var(--color-bg-card)] rounded-xl overflow-hidden group",
        className,
      )}
    >
      <div className="relative h-48 overflow-hidden">
        <Image
          src={image}
          alt={name}
          fill
          className="object-cover transition-transform duration-300 group-hover:scale-105"
        />
      </div>
      <div className="p-6">
        <span className="text-xs text-sky-400 uppercase tracking-wider">
          {category}
        </span>
        <h3 className="mt-2 text-lg font-semibold text-slate-100">{name}</h3>
        <p className="mt-2 text-sm text-slate-400 line-clamp-2">{summary}</p>
        <Link
          href={ROUTES.PRODUCT_DETAIL(slug)}
          className="mt-4 inline-block text-sky-400 text-sm hover:text-sky-300 transition-colors"
        >
          View Details →
        </Link>
      </div>
    </article>
  );
}
```

